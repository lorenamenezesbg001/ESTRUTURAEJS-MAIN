<%- include('../cabecalho.ejs')%>
    <header>
        <h3>Editar Música</h3>
    </header>
    <div class="content">
        <form id="form-instrumento" method="post" autocomplete="off">
            <div class="grid">
                <div>
                    <label for="nome">Nome da Música</label>
                    <input id="nome" value="<%=musica.nome%>" name="nome" type="text" placeholder="Ex:the cure"
                        required>
                </div>
                <div>
                    <label for="nome">Nome do Artista</label>
                    <input id="nome" value="<%=musica.artista%>" name="nome_artista" type="text" placeholder="Ex:Olivia"
                        required>
                </div>
                <div>
                    <label for="nome">Duração</label>
                    <input id="nome" value="<%=musica.duracao%>" name="duracao" type="text" placeholder="Ex:2:00"
                        required>
                </div>
                <div>
                    <label for="nome">Ano de Lançamento</label>
                    <input id="nome" value="<%=musica.ano_Lancamento%>" name="ano" type="text" placeholder="Ex:2000"
                        required>
                </div>
                <div class="field-help">Os campos com * são obrigatórios.</div>
                <footer>
                    <a type="button" class="btn ghost" id="btn-cancelar" href="/musica/lst">Cancelar</a>
                    <button type="submit" class="btn primary">Editar Música</button>
                </footer>
        </form>
    </div>

    <%- include('../rodape.ejs')%>