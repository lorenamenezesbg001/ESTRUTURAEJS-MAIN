<%- include('cabecalho.ejs')%>
    <main class="container">
        <a href="/genero" class="back-link">← Voltar para lista de gênero</a>

        <div class="form-container">
            <h2>Cadastrar Novo Gênero</h2>

            <form method="post">
                <div class="form-group">
                    <label for="nome">Nome do gênero *</label>
                    <input type="text" id="nomegen" name="nomegen">
                </div>

                <div class="form-group">
                    <label for="pais">Descrição *</label>
                    <input type="textarea" id="descricao" name="descricao">
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="genero.ejs" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
    <%- include('rodape.ejs')%>