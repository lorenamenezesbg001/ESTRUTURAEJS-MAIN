<%- include('cabecalho.ejs')%>
    <main class="container">
        <a href="/musica" class="back-link">← Voltar para lista de músicas</a>

        <div class="form-container">
            <h2>Cadastrar Nova Música</h2>

            <form method="post">
                <div class="form-group">
                    <label for="nome">Nome da música *</label>
                    <input type="text" id="nomemus" name="nomemus">
                </div>
                <div class="form-group">
                    <label for="pais">Artista *</label>
                    <input type="text" id="nomartista" name="nomartista">
                </div>
                <div class="form-group">
                    <label for="pais">Gênero *</label>
                    <input type="text" id="genartista" name="genartista">
                </div>
                <div class="form-group">
                    <label for="anoInicio">Ano de Lançamento *</label>
                    <input type="number" id="anoLancamento" name="anoLancamento">
                </div>
                <div class="form-group">
                    <label for="pais">Duração *</label>
                    <input type="text" id="duracao" name="duracao">
                </div>
                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="musica.ejs" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
    <%- include('rodape.ejs')%>