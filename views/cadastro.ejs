<%- include('cabecalho.ejs')%>
    <main class="container">
        <a href="/artista" class="back-link">← Voltar para lista de artistas</a>

        <div class="form-container">
            <h2>Cadastrar Novo Artista</h2>

            <form method="post">
                <div class="form-group">
                    <label for="nome">Nome do Artista *</label>
                    <input type="text" id="nome" name="nome">
                </div>

                <div class="form-group">
                    <label for="pais">País *</label>
                    <input type="text" id="pais" name="pais">
                </div>

                <div class="form-group">
                    <label for="anoInicio">Ano de Início da Carreira *</label>
                    <input type="number" id="anoInicio" name="anoInicio">
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="artista.ejs" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
    <%- include('rodape.ejs')%>