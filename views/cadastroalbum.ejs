<%- include('cabecalho.ejs')%>
    <main class="container">
        <a href="/album" class="back-link">← Voltar para lista de álbuns</a>

        <div class="form-container">
            <h2>Cadastrar Novo Álbum</h2>

            <form method="post">
                <div class="form-group">
                    <label for="nome">Nome do Álbum *</label>
                    <input type="text" id="nomealb" name="nomealb">
                </div>

                <div class="form-group">
                    <label for="pais">Artista *</label>
                    <input type="text" id="artalb" name="artalb">
                </div>
                <div class="form-group">
                    <label for="pais">Ano de publicação *</label>
                    <input type="text" id="anoLancamentoalb" name="anoLancamentoalb">
                </div>
                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="album.ejs" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
    <%- include('rodape.ejs')%>